{
  "name": "luxury-yacht-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,json}\" \"eslint.config.js\" \"vite.config.ts\" \"vitest.setup.ts\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,json}\" \"eslint.config.js\" \"vite.config.ts\" \"vitest.setup.ts\"",
    "lint": "npm run format:check && npm run lint:eslint",
    "lint:eslint": "eslint \"src/**/*.{ts,tsx}\" \"eslint.config.js\" \"vite.config.ts\" \"vitest.setup.ts\"",
    "lint:fix": "npm run format",
    "test": "vitest run",
    "knip": "knip",
    "storybook": "storybook dev -p 6006"
  },
  "dependencies": {
    "@antv/g6": "^5.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@lezer/highlight": "^1.2.3",
    "@uiw/react-codemirror": "^4.25.9",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dayjs": "^1.11.20",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@storybook/react": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "knip": "^6.11.0",
    "prettier": "^3.8.3",
    "storybook": "^10.3.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
