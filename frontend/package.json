{
  "name": "luxury-yacht-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@12.0.1",
  "engines": {
    "node": ">=26.5.0",
    "npm": ">=12.0.1"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check . && npm run check:biome-suppressions",
    "check:fix": "biome check --write . && npm run check:biome-suppressions",
    "check:biome-suppressions": "node scripts/check-biome-suppressions.mjs",
    "test": "vitest run",
    "knip": "knip",
    "storybook": "storybook dev -p 6006"
  },
  "dependencies": {
    "@antv/g": "^6.3.1",
    "@antv/g6": "^5.1.1",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lezer/highlight": "^1.2.3",
    "@uiw/react-codemirror": "^4.25.11",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dayjs": "^1.11.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@storybook/react": "^10.5.2",
    "@storybook/react-vite": "^10.5.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "knip": "^6.27.0",
    "storybook": "^10.5.2",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "unrs-resolver@1.12.2": true
  }
}
