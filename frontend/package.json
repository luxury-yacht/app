{
  "name": "luxury-yacht-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.18.0",
  "engines": {
    "node": ">=26.3.0",
    "npm": ">=11.16.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,css,json}\" \"eslint.config.js\" \"vite.config.ts\" \"vitest.setup.ts\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,css,json}\" \"eslint.config.js\" \"vite.config.ts\" \"vitest.setup.ts\"",
    "lint": "npm run format:check && npm run lint:eslint",
    "lint:eslint": "eslint \"src/**/*.{ts,tsx}\" \"eslint.config.js\" \"vite.config.ts\" \"vitest.setup.ts\"",
    "lint:fix": "npm run format",
    "test": "vitest run",
    "knip": "knip",
    "storybook": "storybook dev -p 6006"
  },
  "dependencies": {
    "@antv/g": "^6.3.1",
    "@antv/g6": "^5.1.1",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@lezer/highlight": "^1.2.3",
    "@uiw/react-codemirror": "^4.25.10",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dayjs": "^1.11.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "knip": "^6.23.0",
    "prettier": "^3.9.4",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true,
    "unrs-resolver@1.12.2": true
  }
}
