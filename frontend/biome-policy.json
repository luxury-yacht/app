{
  "strictness": {
    "rulePreset": "recommended",
    "requiredRules": [
      "a11y.noAutofocus",
      "a11y.noLabelWithoutControl",
      "a11y.noNoninteractiveElementInteractions",
      "a11y.noNoninteractiveTabindex",
      "a11y.noStaticElementInteractions",
      "a11y.useAriaPropsForRole",
      "a11y.useAriaPropsSupportedByRole",
      "a11y.useFocusableInteractive",
      "a11y.useKeyWithClickEvents",
      "a11y.useSemanticElements",
      "a11y.useValidAnchor",
      "complexity.noImportantStyles",
      "complexity.noStaticOnlyClass",
      "complexity.useMaxParams",
      "correctness.noUnresolvedImports",
      "correctness.noUnusedInstantiation",
      "correctness.useImageSize",
      "correctness.useUniqueElementIds",
      "correctness.useExhaustiveDependencies",
      "performance.noDelete",
      "suspicious.noArrayIndexKey",
      "suspicious.noConfusingVoidType",
      "suspicious.noConsole",
      "suspicious.noExplicitAny",
      "suspicious.noEmptyBlockStatements",
      "suspicious.noEvolvingTypes",
      "suspicious.noEqualsToNull",
      "suspicious.noForIn",
      "suspicious.noImportCycles",
      "suspicious.noLeakedRender",
      "suspicious.noMisplacedAssertion",
      "suspicious.noNestedPromises",
      "suspicious.noPrototypeBuiltins",
      "suspicious.noReactForwardRef",
      "suspicious.noReturnAssign",
      "suspicious.noShadow",
      "suspicious.noSkippedTests",
      "suspicious.noUnusedExpressions",
      "suspicious.useGuardForIn",
      "suspicious.useStrictMode",
      "suspicious.useIterableCallbackReturn",
      "style.noDescendingSpecificity",
      "style.noEnum",
      "style.noNonNullAssertion",
      "style.noParameterAssign",
      "style.noParameterProperties",
      "style.noRestrictedImports",
      "style.noUnusedTemplateLiteral",
      "style.useBlockStatements",
      "style.useConsistentObjectDefinitions"
    ],
    "requiredRuleOptions": {
      "complexity.useMaxParams": {
        "max": 7
      },
      "suspicious.noConsole": {
        "allow": ["assert", "error", "group", "groupCollapsed", "groupEnd", "info", "warn"]
      }
    },
    "requiredFileExtensions": ["mjs", "cjs"],
    "requiredScopedRules": [
      {
        "rule": "correctness.noNodejsModules",
        "includes": ["src/**", "!src/**/*.test.*", "!src/**/*.stories.*"]
      }
    ],
    "requiredPlugins": [
      {
        "path": "./biome-plugins/no-direct-fetch.grit",
        "includes": [
          "**/src/**/*.{ts,tsx}",
          "!**/src/core/refresh/**",
          "!**/src/core/data-access/**"
        ]
      },
      {
        "path": "./biome-plugins/no-direct-lifecycle-read.grit",
        "includes": ["**/src/**/*.{ts,tsx}", "!**/src/core/app-state-access/readers.ts"]
      },
      {
        "path": "./biome-plugins/no-direct-permission-read.grit",
        "includes": ["**/src/**/*.{ts,tsx}", "!**/src/core/data-access/readers.ts"]
      },
      {
        "path": "./biome-plugins/no-direct-refresh-orchestrator.grit",
        "includes": [
          "**/src/**/*.{ts,tsx}",
          "!**/src/core/refresh/**",
          "!**/src/core/data-access/**"
        ]
      }
    ]
  },
  "overrides": [
    {
      "includes": ["src/core/backend-api/**"],
      "rules": ["style.noRestrictedImports"],
      "reason": "The approved Wails backend facade must import the generated binding it isolates from application code."
    }
  ],
  "suppressions": []
}
