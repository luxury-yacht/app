{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "root": "..",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**/*.{js,jsx,ts,tsx,css,json,jsonc,html}",
      "!!dist",
      "!!wailsjs",
      "!!package-lock.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "includes": ["**", "!src/core/refresh/types.generated.ts"],
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },
  "assist": {
    "enabled": true,
    "includes": ["**", "!src/core/refresh/types.generated.ts"],
    "actions": {
      "preset": "recommended"
    }
  },
  "linter": {
    "enabled": true,
    "includes": ["**", "!src/core/refresh/types.generated.ts"],
    "rules": {
      "preset": "recommended",
      "a11y": {
        "noAutofocus": "error",
        "noLabelWithoutControl": "error",
        "noNoninteractiveTabindex": "error",
        "noStaticElementInteractions": "error",
        "useAriaPropsForRole": "error",
        "useAriaPropsSupportedByRole": "error",
        "useFocusableInteractive": "error",
        "useKeyWithClickEvents": "error",
        "useSemanticElements": "error",
        "useValidAnchor": "error"
      },
      "complexity": {
        "noImportantStyles": "error",
        "noStaticOnlyClass": "error"
      },
      "correctness": {
        "useExhaustiveDependencies": {
          "level": "error",
          "options": {
            "reportUnnecessaryDependencies": false
          }
        }
      },
      "suspicious": {
        "noArrayIndexKey": "error",
        "noConfusingVoidType": "error",
        "noExplicitAny": "error",
        "noPrototypeBuiltins": "error",
        "useIterableCallbackReturn": {
          "level": "error",
          "options": {
            "checkForEach": true
          }
        }
      },
      "style": {
        "noDescendingSpecificity": "error",
        "noNonNullAssertion": "error",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "@wailsjs/go/backend/App": "Import generated backend bindings only through @/core/backend-api."
            }
          }
        }
      }
    }
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "jsxQuoteStyle": "double",
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  },
  "html": {
    "experimentalFullSupportEnabled": true
  },
  "plugins": [
    {
      "path": "./biome-plugins/no-direct-fetch.grit",
      "includes": ["src/**/*.{ts,tsx}", "!src/core/refresh/**", "!src/core/data-access/**"]
    },
    {
      "path": "./biome-plugins/no-direct-lifecycle-read.grit",
      "includes": ["src/**/*.{ts,tsx}", "!src/core/app-state-access/readers.ts"]
    },
    {
      "path": "./biome-plugins/no-direct-permission-read.grit",
      "includes": ["src/**/*.{ts,tsx}", "!src/core/data-access/readers.ts"]
    },
    {
      "path": "./biome-plugins/no-direct-refresh-orchestrator.grit",
      "includes": ["src/**/*.{ts,tsx}", "!src/core/refresh/**", "!src/core/data-access/**"]
    }
  ],
  "overrides": [
    {
      "includes": ["src/core/backend-api/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    },
    {
      "includes": ["src/**/*.test.{ts,tsx}"],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "off"
          },
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/modules/port-forward/PortForwardModal.tsx",
        "src/shared/components/dropdowns/Dropdown/Dropdown.tsx",
        "src/shared/components/inputs/SearchInput.tsx",
        "src/shared/components/modals/ConfirmationModal.tsx",
        "src/ui/favorites/FavSaveModal.tsx",
        "src/ui/settings/sections/AppearanceSection.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "noAutofocus": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/modules/browse/components/BrowseView.stories.tsx",
        "src/modules/object-map/ObjectMap.tsx",
        "src/shared/components/tables/GridTableBody.tsx",
        "src/shared/components/tables/columnFactories.tsx",
        "src/shared/components/tables/hooks/useGridTableHeaderRow.tsx",
        "src/shared/components/tables/hooks/useGridTableRowRenderer.tsx",
        "src/ui/dockable/DockablePanel.tsx",
        "src/ui/dockable/DockablePanelHeader.tsx",
        "src/ui/panels/app-logs/AppLogsPanel.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "noStaticElementInteractions": "off",
            "useFocusableInteractive": "off",
            "useKeyWithClickEvents": "off",
            "useSemanticElements": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/shared/components/ContextMenu.tsx",
        "src/shared/components/kubernetes/ActionsMenu.tsx",
        "src/ui/command-palette/CommandPalette.tsx",
        "src/ui/favorites/FavMenuDropdown.tsx",
        "src/ui/layout/Sidebar.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "noStaticElementInteractions": "off",
            "useFocusableInteractive": "off",
            "useKeyWithClickEvents": "off",
            "useSemanticElements": "off"
          }
        }
      }
    },
    {
      "includes": ["src/shared/components/dropdowns/Dropdown/Dropdown.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "noStaticElementInteractions": "off",
            "useAriaPropsSupportedByRole": "off",
            "useKeyWithClickEvents": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/modules/object-panel/components/ObjectPanel/ObjectPanel.tsx",
        "src/modules/object-panel/components/ObjectPanel/Shell/ShellTab.tsx",
        "src/shared/components/Tooltip.tsx",
        "src/shared/components/modals/ModalSurface.tsx",
        "src/ui/dockable/DockablePanelControls.tsx",
        "src/ui/dockable/DockableTabBar.tsx",
        "src/ui/layout/AppHeader.tsx",
        "src/ui/layout/AppLayout.tsx",
        "src/ui/settings/sections/AppearanceSection.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "noStaticElementInteractions": "off",
            "useKeyWithClickEvents": "off"
          }
        }
      }
    },
    {
      "includes": ["src/modules/object-panel/components/ObjectPanel/Logs/LogViewer.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "useSemanticElements": "off"
          }
        }
      }
    },
    {
      "includes": ["src/shared/components/diff/DiffViewer.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "noNoninteractiveTabindex": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/modules/object-panel/components/ObjectPanel/Helm/ValuesTab.css",
        "src/modules/object-panel/components/ObjectPanel/Logs/LogViewer.css",
        "src/modules/object-panel/components/ObjectPanel/Shell/ShellTab.css",
        "src/shared/components/KubeconfigSelector.css",
        "src/shared/components/ResourceBar.css",
        "src/ui/command-palette/CommandPalette.css",
        "src/ui/dockable/DockablePanel.css",
        "src/ui/layout/DebugOverlay.css",
        "src/ui/layout/Sidebar.css",
        "src/ui/panels/app-logs/AppLogsPanel.css",
        "styles/components/gridtables.css",
        "styles/utilities/display.css",
        "styles/utilities/motion.css"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noImportantStyles": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/core/refresh/components/DiagnosticsPanel.css",
        "src/modules/object-panel/components/ObjectPanel/Details/DetailsTab.css",
        "src/modules/object-panel/components/ObjectPanel/Logs/LogViewer.css",
        "src/shared/components/ResourceBar.css",
        "src/shared/components/diff/DiffViewer.css",
        "src/shared/components/errors/ErrorNotificationSystem.css",
        "src/ui/command-palette/CommandPalette.css",
        "src/ui/dockable/DockablePanel.css",
        "src/ui/layout/Sidebar.css",
        "src/ui/modals/ObjectDiffModal.css",
        "src/ui/panels/app-logs/AppLogsPanel.css",
        "styles/base/scrollbars.css",
        "styles/components/dropdowns.css",
        "styles/components/gridtables.css",
        "styles/components/tabs.css",
        "styles/utilities/motion.css"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDescendingSpecificity": "off"
          }
        }
      }
    },
    {
      "includes": ["src/shared/components/icons/**"],
      "linter": {
        "rules": {
          "a11y": {
            "noSvgWithoutTitle": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/modules/object-panel/components/ObjectPanel/Logs/ansi.ts",
        "src/modules/object-panel/components/ObjectPanel/Shell/ShellTab.tsx"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noControlCharactersInRegex": "off"
          }
        }
      }
    },
    {
      "includes": ["index.html"],
      "linter": {
        "rules": {
          "correctness": {
            "noInnerDeclarations": "off"
          }
        }
      }
    },
    {
      "includes": [
        "src/core/contexts/**/*.test.{ts,tsx}",
        "src/core/connection/**/*.test.{ts,tsx}",
        "src/core/data-access/**/*.test.{ts,tsx}",
        "src/core/events/**/*.test.{ts,tsx}",
        "src/core/logging/**/*.test.{ts,tsx}",
        "src/core/persistence/**/*.test.{ts,tsx}",
        "src/core/resource-metrics/**/*.test.{ts,tsx}",
        "src/core/settings/**/*.test.{ts,tsx}",
        "src/hooks/**/*.test.{ts,tsx}",
        "src/shared/utils/**/*.test.{ts,tsx}",
        "src/utils/**/*.test.{ts,tsx}"
      ],
      "linter": {
        "rules": {
          "style": {
            "noNonNullAssertion": "error"
          },
          "suspicious": {
            "noExplicitAny": "error"
          }
        }
      }
    }
  ]
}
