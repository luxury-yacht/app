engine biome(1.0)
language js(typescript, jsx)

// Keep cluster lifecycle reads behind appStateAccess so callers use the shared application-state
// boundary. The plugin scope exempts the appStateAccess reader that performs the runtime call.
`$receiver.GetAllClusterLifecycleStates($...)` as $call where {
  register_diagnostic(
    span = $call,
    message = "Route lifecycle state reads through appStateAccess instead of calling runtime methods directly.",
    severity = "error"
  )
}
